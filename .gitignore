# Personal data and local state — never commit these. Each has a
# .example counterpart with dummy data showing the expected format.

# Your Google Contacts export (scripts/export_contacts.sh) — real email
# addresses of everyone you've ever emailed.
/contacts_emails.txt

# Senders you've curated as safe to prune aggressively — real addresses.
/noisy_senders.txt

# Per-message audit trail (timestamps, senders, subjects, message IDs).
/audit_log.jsonl

# Running history of prune/rescue/label runs (queries, counts, dates).
/PRUNE_LOG.md

# Timestamp marker written by label_reference.sh.
/.label_reference_last_run

# Personal scratch notes (setup notes, personal queries) — not part of
# the toolkit.
/NOTES.md

# Personal "keep" rules (specific people/services for rescue.sh and
# label_reference.sh) — see config/keep_rules.local.example.tsv.
/config/keep_rules.local.tsv

# Industry/org-specific sender rules for prune.sh — personal professional
# affiliations; see config/prune_industry_senders.local.example.conf.
/config/prune_industry_senders.local.conf

# Python tooling (python/)
# The lockfile (uv.lock) IS committed — it pins exact dependency versions.
# The .venv and compiled SQLite databases are not.
/python/.venv/
/python/__pycache__/
/python/**/__pycache__/
/python/*.pyc
/python/gmail.db
/python/gmail.db-shm
/python/gmail.db-wal

# Classification results — contain real email content (message IDs, subjects,
# sender addresses, model reasoning quoting email body text). Never commit.
/python/classifications.db
/python/disagreements.jsonl
/python/errors.jsonl

# Tool caches
/python/.mypy_cache/
/python/.ruff_cache/
/python/.pytest_cache/

# gstack skill outputs (security reports, learnings, decision logs) — local only.
/.gstack/
